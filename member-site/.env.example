# ローカル: docker compose up -d 後の例
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/membersite?schema=public"

# 本番（Neon / Supabase / Vercel Postgres 等の接続文字列）
# DATABASE_URL="postgresql://..."

SESSION_SECRET="change-me-minimum-32-characters-long-secret"
DEMO_MONTHLY_PASSWORD="your-monthly-password"
CONTACT_TO_EMAIL="you@example.com"

# 本番URL（メール本文のリンク用。未設定時は localhost 扱い）
# NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# 公開ツールサイトのオリジン（/links からシミュレーター等へ飛ばす用。未設定時は https://www.familymoney.jp）
# NEXT_PUBLIC_PUBLIC_SITE_URL="https://www.familymoney.jp"

# RESEND_API_KEY="re_..."
